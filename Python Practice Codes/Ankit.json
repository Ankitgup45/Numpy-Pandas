        "name": "Sales_ETL_Pipeline",
        "schedule": {
          "cron": "0 */6 * * *",
          "timezone": "Asia/Kolkata"
        },
        "stages": [
          {
            "stage": "extract",
            "source": {
              "type": "sql",
              "connection": {
                "host": "db.prod.internal",
                "port": 5432,
                "database": "sales_db"
              },
              "query": "SELECT * FROM transactions WHERE updated_at > NOW() - INTERVAL '6 HOURS'"
            }
          },
          {
            "stage": "transform",
            "operations": [
              { "type": "filter", "condition": "amount > 0" },
              { "type": "map", "script": "normalize_currency" },
              { "type": "aggregate", "group_by": ["region"], "metrics": ["sum(amount)"] }
            ]
          },
          {
            "stage": "load",
            "destination": {
              "type": "data_warehouse",
              "target_table": "dw_sales_summary",
              "mode": "upsert"
            }
          }
        ],
